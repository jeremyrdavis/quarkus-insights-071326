                  "    const body = pm.response.json();",
                  "    pm.expect(body.id).to.eql(pm.collectionVariables.get('createdCfpId'));",
                  "    pm.expect(body.conferenceName).to.eql('Postman Test Conference 2027');",
                  "});"
                ]
              }
            }
          ]
        },
