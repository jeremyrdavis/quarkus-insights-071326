          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Conference name is updated', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.conferenceName).to.eql('Postman Test Conference 2027 (Updated)');",
                  "});",
                  "pm.test('CFP dates are updated', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.cfpOpens).to.eql('2027-02-01');",
                  "    pm.expect(body.cfpCloses).to.eql('2027-04-30');",
                  "});"
                ]
              }
            }
          ]
        },
