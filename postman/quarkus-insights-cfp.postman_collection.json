    {
      "name": "Session Proposals",
      "item": [
        {
          "name": "POST Create Session Proposal (Open CFP)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cfpId\": \"44444444-4444-4444-4444-444444444444\",\n  \"title\": \"Getting Started with Quarkus\",\n  \"description\": \"An introduction to building cloud-native Java applications with Quarkus — from zero to a fully containerised microservice.\",\n  \"conferenceSessionFormat\": {\n    \"formatCode\": \"TECHNICAL_SESSION\",\n    \"title\": \"Technical Session\",\n    \"description\": \"A standard technical talk\",\n    \"duration\": \"PT45M\"\n  },\n  \"conferenceTrack\": {\n    \"trackCode\": \"SERVER_SIDE_JAVA\",\n    \"title\": \"Server-Side Java\",\n    \"description\": \"Frameworks and libraries for server-side Java development\"\n  },\n  \"level\": \"BEGINNER\",\n  \"language\": \"ENGLISH\",\n  \"presenterEmail\": \"speaker@example.com\",\n  \"presentationOutline\": \"1. What is Quarkus?  2. Live coding demo  3. Native image build  4. Q&A\",\n  \"programmingLanguagesUsed\": [\n    { \"language\": \"Java\" }\n  ],\n  \"preRequisiteKnowledge\": \"Basic Java knowledge required\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/session-proposals",
              "host": ["{{baseUrl}}"],
              "path": ["session-proposals"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Title matches', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.title).to.eql('Getting Started with Quarkus');",
                  "});",
                  "pm.test('Format and track are present', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.conferenceSessionFormat).to.be.an('object');",
                  "    pm.expect(body.conferenceTrack).to.be.an('object');",
                  "});",
                  "pm.test('Level and language match', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.level).to.eql('BEGINNER');",
                  "    pm.expect(body.language).to.eql('ENGLISH');",
                  "});",
                  "pm.test('Programming languages are present', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.programmingLanguagesUsed).to.be.an('array').with.lengthOf(1);",
                  "});"
                ]
              }
            }
          ]
        },
