{
  "info": {
    "name": "Quarkus Insights CFP API",
    "description": "Test suite for the Quarkus Insights Conference Call-for-Papers REST API.\n\nRun the collection in order — POST requests capture IDs/emails into collection variables used by later requests.\n\nSeed data UUIDs:\n  - CFP (closed Jan–Mar 2026): 11111111-1111-1111-1111-111111111111\n  - CFP (open Jul–Sep 2026):   44444444-4444-4444-4444-444444444444",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "createdCfpId",
      "value": "",
      "type": "string"
    },
    {
      "key": "createdPresenterEmail",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "CFP",
      "item": [
        {
          "name": "GET All CFPs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/cfp",
              "host": ["{{baseUrl}}"],
              "path": ["cfp"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns an array', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.be.an('array');",
                  "});",
                  "pm.test('Contains at least the 2 seeded CFPs', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.length).to.be.at.least(2);",
                  "});",
                  "pm.test('Each CFP has an id and conferenceName', () => {",
                  "    const body = pm.response.json();",
                  "    body.forEach(cfp => {",
                  "        pm.expect(cfp).to.have.property('id');",
                  "        pm.expect(cfp).to.have.property('conferenceName');",
                  "    });",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET CFP by ID - Seed (Quarkus Insights Conference)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/cfp/11111111-1111-1111-1111-111111111111",
              "host": ["{{baseUrl}}"],
              "path": ["cfp", "11111111-1111-1111-1111-111111111111"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Correct conference name', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.conferenceName).to.eql('Quarkus Insights Conference');",
                  "});",
                  "pm.test('Has formats and tracks', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.conferenceSessionFormats).to.be.an('array').with.length.above(0);",
                  "    pm.expect(body.tracks).to.be.an('array').with.length.above(0);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET CFP by ID - Not Found",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/cfp/00000000-0000-0000-0000-000000000000",
              "host": ["{{baseUrl}}"],
              "path": ["cfp", "00000000-0000-0000-0000-000000000000"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 404 for unknown ID', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST Create CFP",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cfpOpens\": \"2027-01-01\",\n  \"cfpCloses\": \"2027-03-31\",\n  \"conferenceName\": \"Postman Test Conference 2027\",\n  \"conferenceUrl\": \"https://postmantest2027.io\",\n  \"conferenceDescription\": \"A conference created via the Postman test suite to verify CFP creation.\",\n  \"contactEmailAddress\": \"cfp@postmantest2027.io\",\n  \"conferenceTracks\": [\n    {\n      \"trackCode\": \"JAVA_LANGUAGE\",\n      \"title\": \"Java Language\",\n      \"description\": \"The Java language, new features, and the JVM\"\n    },\n    {\n      \"trackCode\": \"CLOUD\",\n      \"title\": \"Cloud\",\n      \"description\": \"Cloud-native development and Kubernetes\"\n    }\n  ],\n  \"formats\": [\n    {\n      \"formatCode\": \"TECHNICAL_SESSION\",\n      \"title\": \"Technical Session\",\n      \"description\": \"A standard 45-minute technical talk\",\n      \"duration\": \"PT45M\"\n    },\n    {\n      \"formatCode\": \"HANDS_ON_LAB\",\n      \"title\": \"Hands-on Lab\",\n      \"description\": \"A 2-hour interactive workshop\",\n      \"duration\": \"PT2H\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/cfp",
              "host": ["{{baseUrl}}"],
              "path": ["cfp"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Response has an id', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.id).to.be.a('string').and.have.length.above(0);",
                  "    pm.collectionVariables.set('createdCfpId', body.id);",
                  "});",
                  "pm.test('Conference name matches', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.conferenceName).to.eql('Postman Test Conference 2027');",
                  "});",
                  "pm.test('Has 2 formats', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.conferenceSessionFormats).to.be.an('array').with.lengthOf(2);",
                  "});",
                  "pm.test('Has 2 tracks', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.tracks).to.be.an('array').with.lengthOf(2);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET CFP by ID - Created",
          "request": {
